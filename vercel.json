{
  "buildCommand": "cd fia-institute-portal && npm install && npm run build",
  "outputDirectory": "fia-institute-portal/dist",
  "installCommand": "cd fia-institute-portal && npm install",
  "framework": "vite",
  "redirects": [
    {
      "source": "/vivasense/workspace/:path*",
      "destination": "/vivasense/genetics/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/vivasense",
      "destination": "/index.html"
    },
    {
      "source": "/vivasense/:path*",
      "destination": "/index.html"
    }
  ]
}
